# PostgreSQL 数据库连接（Prisma 驱动，用于聊天历史持久化）
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# 生产建议: ...?schema=public&sslmode=require&channel_binding=require（配合 PG 侧 scram-sha-256）
DATABASE_URL=postgresql://postgres:password@localhost:5432/main_platform?schema=public

# 聊天历史存储模式（默认 prisma，不设置等同于显式写 prisma）
# prisma → 强制 Prisma，数据库不可用时直接报 503，不降级（默认）
# auto   → 优先 Prisma，失败后自动降级内存 Mock（不推荐生产使用）
# mock   → 始终使用内存 Mock（纯前端演示/离线开发用，服务重启数据丢失）
# CHAT_HISTORY_STORAGE_MODE=prisma

# Python 中心聚合服务地址（global 模式联邦检索）
FEDERATION_CENTRAL_BASE_URL=https://uu798805-ub7m-2f7ebadd.westd.seetacloud.com:8443

# 联邦链路 TLS 强制策略（默认 true）
# true  -> 仅允许 HTTPS（可通过 FEDERATION_ALLOW_HTTP_LOCALHOST 放行本机回环地址 HTTP）
# false -> 允许任意 HTTP/HTTPS（仅建议本地临时联调）
# FEDERATION_REQUIRE_TLS=true

# 允许本机回环地址使用 HTTP（默认 true）
# 若为 false，则 localhost/127.0.0.1 也必须使用 HTTPS
# FEDERATION_ALLOW_HTTP_LOCALHOST=true

# BFF <-> central <-> node 内部鉴权令牌（建议高强度随机字符串）
# 默认要求配置该值（除非显式 FEDERATION_REQUIRE_INTERNAL_TOKEN=false）
# FEDERATION_INTERNAL_TOKEN=replace-with-a-strong-shared-token

# 是否强制要求内部鉴权令牌（默认 true）
# FEDERATION_REQUIRE_INTERNAL_TOKEN=true

# BFF -> central 请求超时（毫秒，默认 15000）
FEDERATION_CENTRAL_TIMEOUT_MS=15000

# BFF health 检查 central 超时（毫秒，默认 5000）
FEDERATION_CENTRAL_HEALTH_TIMEOUT_MS=5000

# 可选：BFF 直连节点健康检查（逗号分隔 node=url）
# FEDERATION_NODE_HEALTH_URLS=nodea=http://127.0.0.1:8001,nodeb=http://127.0.0.1:8002,nodec=http://127.0.0.1:8003

# 节点健康检查超时（毫秒，默认 8000）
FEDERATION_NODE_TIMEOUT_MS=8000

# Python central/node 共享 SM4 密钥（长度不足会补齐到 16 字节）
FEDERATION_SM4_KEY=replace-with-your-sm4-key

# Node API 鉴权默认严格模式（默认 true）
# NODE_AUTH_STRICT_MODE=true

# 仅在非生产环境下可用：允许 NODE_AUTH_STRICT_MODE=false 时跳过认证头（默认关闭）
# NODE_AUTH_ALLOW_INSECURE_BYPASS=false

# ─── MiA-RAG 后端接入 ──────────────────────────────────────────────
# 本地模式检索：Next.js BFF 直连 pythonproject3_mia 的 node_server.py 内部查询端点
# 生产环境必须设置，否则本地检索不可用
MIA_RAG_NODE_URL=https://u798805-ub7m-2f7ebadd.westd.seetacloud.com:8443

# 真实登录/注册接入：指向 pythonproject3_mia 的 node_server.py 或 api/main.py 的 auth 路由
# 不设置时使用前端 mock 登录（admin/311311）
NEXT_PUBLIC_MIA_RAG_AUTH_URL=https://u798805-ub7m-2f7ebadd.westd.seetacloud.com:8443
